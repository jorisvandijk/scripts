#!/usr/bin/env bash
#	jHugoHelper 2.2
#	Hugo site helper: server, new post, new status
#	Dependencies: hugo, micro
#	Usage: jHugoHelper {server|new|status} [post-name]
#
#	By Joris van Dijk | Jorisvandijk.com
#	Licensed under the MIT license

source "$(dirname "${BASH_SOURCE[0]}")/j"

[[ "$1" == "--version" || "$1" == "-v" ]] && j::version "$0" && exit 0
[[ "$1" == "--help"    || "$1" == "-h" ]] && j::help "jHugoHelper" && exit 0

case "$1" in
    server)
        cd ~/git/website || j::die "could not cd to ~/git/website"
        hugo server -D
        rm ~/git/website/.hugo_build.lock 2>/dev/null
        ;;
    new)
        [[ -z "$2" ]] && j::die "post name required — usage: jHugoHelper new <post-name>"
        cd ~/git/website || j::die "could not cd to ~/git/website"
        hugo new "posts/${2}.md"
        filepath="content/posts/${2}.md"
        before="$(cat "$filepath")"
        micro "$filepath"
        [[ "$(cat "$filepath")" == "$before" ]] && rm "$filepath" && j::die "no changes — post discarded"
        ;;
    status)
        cd ~/git/website || j::die "could not cd to ~/git/website"
        timestamp="$(date +%Y-%m-%d-%H%M%S)"
        filepath="content/microblog/${timestamp}.md"
        [[ -e "$filepath" ]] && j::die "${filepath} already exists"
        hugo new "microblog/${timestamp}.md"
        before="$(cat "$filepath")"
        micro "$filepath"
        [[ "$(cat "$filepath")" == "$before" ]] && rm "$filepath" && j::die "no changes — status discarded"
        ;;
    *)
        j::die "usage: jHugoHelper {server|new|status} [post-name]"
        ;;
esac
