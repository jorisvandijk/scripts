#!/bin/zsh
case "$1" in
    server)
        cd ~/git/website
        hugo server -D
        rm ~/git/website/.hugo_build.lock 2>/dev/null
        ;;
    new)
        if [ -z "$2" ]; then
            echo "Error: Post name required" >&2
            echo "Usage: hn <post-name>" >&2
            return 1
        fi
        cd ~/git/website
        hugo new "posts/${2}.md"
        micro content/posts/"${2}.md"
        ;;
    status)
        cd ~/git/website || return 1
        local timestamp
        timestamp=$(date +%Y-%m-%d-%H%M%S)
        local filepath="content/status/${timestamp}.md"

        if [ -e "${filepath}" ]; then
            echo "Error: ${filepath} already exists" >&2
            return 1
        fi

        hugo new "status/${timestamp}.md"
        micro "${filepath}"
        ;;
    *)
        echo "Usage: hugo-helper {server|new|status} [post-name]" >&2
        return 1
        ;;
esac
