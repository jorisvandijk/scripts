#!/bin/bash

GIT_BASE_DIR="${HOME}/git"

if [[ -t 1 ]]; then
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN=''
    YELLOW=''
    RED=''
    NC=''
fi

classify_status() {
    local status="$1"
    if [[ "$status" == "clean" ]]; then
        echo "clean"
    elif [[ "$status" =~ (ahead|behind) ]]; then
        echo "sync"
    else
        echo "dirty"
    fi
}

get_repo_status() {
    local repo_path="$1"
    if [[ ! -d "$repo_path" ]]; then
        echo "repository not found"
        return
    fi
    
    if [[ ! -d "$repo_path/.git" ]]; then
        echo "not a git repo"
        return
    fi
    
    cd "$repo_path" || return
    
    local status_output=$(git status --porcelain 2>/dev/null)
    local ahead_behind=$(git rev-list --count --left-right @{upstream}...HEAD 2>/dev/null || echo "0	0")
    local behind=$(echo "$ahead_behind" | cut -f1)
    local ahead=$(echo "$ahead_behind" | cut -f2)
    
    local status_parts=()
    
    if [[ -n "$status_output" ]]; then
        local modified=$(echo "$status_output" | grep -c "^.M\|^M")
        local untracked=$(echo "$status_output" | grep -c "^??")
        local staged=$(echo "$status_output" | grep -c "^[MADRC]")
        
        [[ $staged -gt 0 ]] && status_parts+=("$staged staged")
        [[ $modified -gt 0 ]] && status_parts+=("$modified modified")
        [[ $untracked -gt 0 ]] && status_parts+=("$untracked untracked")
    fi
    
    [[ $ahead -gt 0 ]] && status_parts+=("ahead $ahead")
    [[ $behind -gt 0 ]] && status_parts+=("behind $behind")
    
    if [[ ${#status_parts[@]} -eq 0 ]]; then
        echo "clean"
    else
        local IFS=" "
        echo "${status_parts[*]}"
    fi
}

list_repos() {
    if [[ ! -d "$GIT_BASE_DIR" ]]; then
        echo "Error: Git directory does not exist: $GIT_BASE_DIR"
        exit 1
    fi

    local sync_entries=()
    local dirty_entries=()
    local clean_entries=()

    for repo_dir in "$GIT_BASE_DIR"/*; do
        if [[ -d "$repo_dir/.git" ]]; then
            local repo_name=$(basename "$repo_dir")
            local repo_status=$(get_repo_status "$repo_dir")
            local classification=$(classify_status "$repo_status")

            case "$classification" in
                sync)
                    sync_entries+=("$repo_name|$repo_status")
                    ;;
                dirty)
                    dirty_entries+=("$repo_name|$repo_status")
                    ;;
                clean)
                    clean_entries+=("$repo_name|$repo_status")
                    ;;
            esac
        fi
    done

    local total=$((${#sync_entries[@]} + ${#dirty_entries[@]} + ${#clean_entries[@]}))
    if [[ $total -eq 0 ]]; then
        echo "No git repositories found in: $GIT_BASE_DIR"
        exit 0
    fi

    for entry in "${sync_entries[@]}"; do
        local name="${entry%|*}"
        local status="${entry#*|}"
        printf "${RED}%-20s ${status}${NC}\n" "$name"
    done

    for entry in "${dirty_entries[@]}"; do
        local name="${entry%|*}"
        local status="${entry#*|}"
        printf "${YELLOW}%-20s ${status}${NC}\n" "$name"
    done

    for entry in "${clean_entries[@]}"; do
        local name="${entry%|*}"
        local status="${entry#*|}"
        printf "${GREEN}%-20s ${status}${NC}\n" "$name"
    done
}

show_usage() {
    echo "Usage: repos"
    echo "Lists all git repositories in: $GIT_BASE_DIR"
}

if [[ -n "$1" ]]; then
    show_usage
    exit 1
fi

list_repos