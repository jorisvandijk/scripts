#!/usr/bin/env bash
# list - eza wrapper with sane defaults (macOS / Homebrew bash)

opts=(
  -l -b                        # long format (table), binary size units (KiB, MiB, ...)
  --header                     # show column headers
  --color=always               # force color even if output is piped
  --group-directories-first    # list directories before files
  --git                        # show per-file git status column (modified/staged etc.)
  --git-repos                  # mark subdirs that are git repo roots (branch + clean/dirty)
  --icons                      # show file-type icons (needs Nerd Font, used in Kitty)
  --hyperlink                  # make entries clickable (Cmd-click to open in Kitty)
  --time-style=long-iso   	   # always show YYYY-MM-DD HH:MM, regardless of file age
  #-O                           # show macOS file flags (e.g. hidden, locked via chflags)
)

extra=()        
show_hidden=0   

for arg in "$@"; do
  case "$arg" in
    -a|--all) show_hidden=1 ;;  
  esac
done

if [[ "$show_hidden" -eq 0 && "$PWD" == "$HOME" ]]; then
  extra=(--ignore-glob "Music|Movies|Pictures|Applications|Desktop|Library")  
fi

exec eza "${opts[@]}" "${extra[@]}" "$@" 
