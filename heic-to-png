#!/bin/bash

convert_file() {
  local input="$1"
  local output="${input%.*}.png"

  if [ ! -f "$input" ]; then
    echo "Error: File not found: $input" >&2
    return 1
  fi

  if [ -f "$output" ]; then
    echo "Error: Output file already exists: $output" >&2
    return 1
  fi

  /usr/bin/sips -s format png "$input" --out "$output" 2>/dev/null

  if [ $? -eq 0 ]; then
    echo "Converted: $input -> $output"
  else
    echo "Error: Failed to convert $input" >&2
    return 1
  fi
}

if [ $# -eq 0 ]; then
  echo "Usage: heic-to-png <file1> [file2] ..." >&2
  exit 1
fi

for file in "$@"; do
  convert_file "$file"
done
