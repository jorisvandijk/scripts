#!/usr/bin/env bash
#	jNewRepo 2.0
#	Initialize a local git repo and create it on GitHub, GitLab, Codeberg, and Bitbucket
#	Dependencies: git, curl
#	Usage: jNewRepo [--private] [--desc "description"] REPO_NAME REPO_PATH
#
#	By Joris van Dijk | Jorisvandijk.com
#	Licensed under the MIT license

source "$(dirname "${BASH_SOURCE[0]}")/j"

[[ "$1" == "--version" || "$1" == "-v" ]] && j::version "$0" && exit 0
[[ "$1" == "--help"    || "$1" == "-h" ]] && j::help "jNewRepo" && exit 0

PRIVATE=false
DESCRIPTION=""

while [ $# -gt 0 ]; do
    case "$1" in
        --private) PRIVATE=true; shift ;;
        --desc)    DESCRIPTION="$2"; shift 2 ;;
        --)        shift; break ;;
        -*)        j::die "unknown option: $1" ;;
        *)         break ;;
    esac
done

[ $# -ne 2 ] && j::die "usage: jNewRepo [--private] [--desc 'description'] REPO_NAME REPO_PATH"

REPO_NAME="$1"
REPO_PATH="$2"

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME}/git/documents/newrepo/config"

if [ ! -f "$CONFIG_FILE" ]; then
    printf "Error: Config file not found at %s\n\n" "$CONFIG_FILE"
    printf "Create it with:\n\n"
    printf "  mkdir -p \"\$(dirname %s)\"\n" "$CONFIG_FILE"
    printf "  touch %s && chmod 600 %s\n\n" "$CONFIG_FILE" "$CONFIG_FILE"
    printf "Then add (quote all values):\n\n"
    printf "  GITHUB_TOKEN=\"your_token_here\"\n"
    printf "  GITLAB_TOKEN=\"your_token_here\"\n"
    printf "  CODEBERG_TOKEN=\"your_token_here\"\n"
    printf "  BITBUCKET_WORKSPACE=\"jorisvdijk\"\n"
    printf "  BITBUCKET_EMAIL=\"your_atlassian_email_here\"\n"
    printf "  BITBUCKET_API_TOKEN=\"your_api_token_here\"\n\n"
    printf "Token scopes needed:\n"
    printf "  GitHub:    repo (or public_repo for public repos)\n"
    printf "  GitLab:    api\n"
    printf "  Codeberg:  read:user + write:repository\n"
    printf "  Bitbucket: Repositories (read + write)\n"
    exit 1
fi

# shellcheck source=/dev/null
. "$CONFIG_FILE"

[ ! -d "$REPO_PATH" ]      && j::die "directory '$REPO_PATH' does not exist"
[ -d "$REPO_PATH/.git" ]   && j::die "'$REPO_PATH' already has a .git directory"

# ── Preflight checks ─────────────────────────────────────────────────────────

PREFLIGHT_FAILED=false

check_auth_github() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        https://api.github.com/user)
    [ "$code" = "200" ] && return 0
    printf "  GitHub auth...   FAIL (invalid token, HTTP %s)\n" "$code"; return 1
}

check_exists_github() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/jorisvandijk/$REPO_NAME")
    case "$code" in
        404) printf "  GitHub repo...   OK\n"; return 0 ;;
        200) printf "  GitHub repo...   FAIL (already exists)\n"; return 1 ;;
        *)   printf "  GitHub repo...   FAIL (unexpected HTTP %s)\n" "$code"; return 1 ;;
    esac
}

check_auth_gitlab() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "PRIVATE-TOKEN: $GITLAB_TOKEN" \
        https://gitlab.com/api/v4/user)
    [ "$code" = "200" ] && return 0
    printf "  GitLab auth...   FAIL (invalid token, HTTP %s)\n" "$code"; return 1
}

check_exists_gitlab() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "PRIVATE-TOKEN: $GITLAB_TOKEN" \
        "https://gitlab.com/api/v4/projects/jorisvandijk%2F$REPO_NAME")
    case "$code" in
        404) printf "  GitLab repo...   OK\n"; return 0 ;;
        200) printf "  GitLab repo...   FAIL (already exists)\n"; return 1 ;;
        *)   printf "  GitLab repo...   FAIL (unexpected HTTP %s)\n" "$code"; return 1 ;;
    esac
}

check_auth_codeberg() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: token $CODEBERG_TOKEN" \
        https://codeberg.org/api/v1/user)
    [ "$code" = "200" ] && return 0
    printf "  Codeberg auth... FAIL (invalid token, HTTP %s)\n" "$code"; return 1
}

check_exists_codeberg() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: token $CODEBERG_TOKEN" \
        "https://codeberg.org/api/v1/repos/jorisvandijk/$REPO_NAME")
    case "$code" in
        404) printf "  Codeberg repo... OK\n"; return 0 ;;
        200) printf "  Codeberg repo... FAIL (already exists)\n"; return 1 ;;
        *)   printf "  Codeberg repo... FAIL (unexpected HTTP %s)\n" "$code"; return 1 ;;
    esac
}

check_auth_bitbucket() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -u "$BITBUCKET_EMAIL:$BITBUCKET_API_TOKEN" \
        https://api.bitbucket.org/2.0/user)
    [ "$code" = "200" ] && return 0
    printf "  Bitbucket auth...FAIL (invalid credentials, HTTP %s)\n" "$code"; return 1
}

check_exists_bitbucket() {
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" \
        -u "$BITBUCKET_EMAIL:$BITBUCKET_API_TOKEN" \
        "https://api.bitbucket.org/2.0/repositories/$BITBUCKET_WORKSPACE/$REPO_NAME")
    case "$code" in
        404) printf "  Bitbucket repo...OK\n"; return 0 ;;
        200) printf "  Bitbucket repo...FAIL (already exists)\n"; return 1 ;;
        *)   printf "  Bitbucket repo...FAIL (unexpected HTTP %s)\n" "$code"; return 1 ;;
    esac
}

printf "Preflight checks for '%s'...\n" "$REPO_NAME"
check_auth_github    || PREFLIGHT_FAILED=true
check_exists_github  || PREFLIGHT_FAILED=true
check_auth_gitlab    || PREFLIGHT_FAILED=true
check_exists_gitlab  || PREFLIGHT_FAILED=true
check_auth_codeberg  || PREFLIGHT_FAILED=true
check_exists_codeberg  || PREFLIGHT_FAILED=true
check_auth_bitbucket || PREFLIGHT_FAILED=true
check_exists_bitbucket || PREFLIGHT_FAILED=true

[ "$PREFLIGHT_FAILED" = true ] && printf "\nPreflight failed. Nothing was created.\n" && exit 1

# ── Create on all platforms ───────────────────────────────────────────────────

printf "\nCreating remote repositories...\n"

create_github() {
    printf "  GitHub...    "
    PRIVATE_VAL=$([ "$PRIVATE" = true ] && printf "true" || printf "false")
    HTTP_CODE=$(curl -s -o /tmp/newrepo_gh.json -w "%{http_code}" \
        -X POST \
        -H "Authorization: Bearer $GITHUB_TOKEN" \
        -H "Accept: application/vnd.github+json" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        https://api.github.com/user/repos \
        -d "{\"name\":\"$REPO_NAME\",\"description\":\"$DESCRIPTION\",\"private\":$PRIVATE_VAL}")
    if [ "$HTTP_CODE" = "201" ]; then
        printf "OK\n"
    else
        MSG=$(grep -o '"message":"[^"]*"' /tmp/newrepo_gh.json 2>/dev/null | head -1 | cut -d'"' -f4)
        printf "FAILED (HTTP %s: %s)\n" "$HTTP_CODE" "$MSG"
        rm -f /tmp/newrepo_gh.json
        return 1
    fi
    rm -f /tmp/newrepo_gh.json
}

create_gitlab() {
    printf "  GitLab...    "
    VISIBILITY=$([ "$PRIVATE" = true ] && printf "private" || printf "public")
    HTTP_CODE=$(curl -s -o /tmp/newrepo_gl.json -w "%{http_code}" \
        -X POST \
        -H "PRIVATE-TOKEN: $GITLAB_TOKEN" \
        -H "Content-Type: application/json" \
        https://gitlab.com/api/v4/projects \
        -d "{\"name\":\"$REPO_NAME\",\"description\":\"$DESCRIPTION\",\"visibility\":\"$VISIBILITY\",\"initialize_with_readme\":false}")
    if [ "$HTTP_CODE" = "201" ]; then
        printf "OK\n"
    else
        MSG=$(grep -o '"message":"[^"]*"' /tmp/newrepo_gl.json 2>/dev/null | head -1 | cut -d'"' -f4)
        printf "FAILED (HTTP %s: %s)\n" "$HTTP_CODE" "$MSG"
        rm -f /tmp/newrepo_gl.json
        return 1
    fi
    rm -f /tmp/newrepo_gl.json
}

create_codeberg() {
    printf "  Codeberg...  "
    PRIVATE_VAL=$([ "$PRIVATE" = true ] && printf "true" || printf "false")
    HTTP_CODE=$(curl -s -o /tmp/newrepo_cb.json -w "%{http_code}" \
        -X POST \
        -H "Authorization: token $CODEBERG_TOKEN" \
        -H "Content-Type: application/json" \
        https://codeberg.org/api/v1/user/repos \
        -d "{\"name\":\"$REPO_NAME\",\"description\":\"$DESCRIPTION\",\"private\":$PRIVATE_VAL,\"auto_init\":false}")
    if [ "$HTTP_CODE" = "201" ]; then
        printf "OK\n"
    else
        MSG=$(grep -o '"message":"[^"]*"' /tmp/newrepo_cb.json 2>/dev/null | head -1 | cut -d'"' -f4)
        printf "FAILED (HTTP %s: %s)\n" "$HTTP_CODE" "$MSG"
        rm -f /tmp/newrepo_cb.json
        return 1
    fi
    rm -f /tmp/newrepo_cb.json
}

create_bitbucket() {
    printf "  Bitbucket... "
    IS_PRIVATE=$([ "$PRIVATE" = true ] && printf "true" || printf "false")
    HTTP_CODE=$(curl -s -o /tmp/newrepo_bb.json -w "%{http_code}" \
        -X POST \
        -u "$BITBUCKET_EMAIL:$BITBUCKET_API_TOKEN" \
        -H "Content-Type: application/json" \
        "https://api.bitbucket.org/2.0/repositories/$BITBUCKET_WORKSPACE/$REPO_NAME" \
        -d "{\"scm\":\"git\",\"is_private\":$IS_PRIVATE,\"description\":\"$DESCRIPTION\"}")
    if [ "$HTTP_CODE" = "200" ] || [ "$HTTP_CODE" = "201" ]; then
        printf "OK\n"
    else
        MSG=$(grep -o '"message":"[^"]*"' /tmp/newrepo_bb.json 2>/dev/null | head -1 | cut -d'"' -f4)
        printf "FAILED (HTTP %s: %s)\n" "$HTTP_CODE" "$MSG"
        rm -f /tmp/newrepo_bb.json
        return 1
    fi
    rm -f /tmp/newrepo_bb.json
}

create_github    || exit 1
create_gitlab    || exit 1
create_codeberg  || exit 1
create_bitbucket || exit 1

# ── Local git setup ───────────────────────────────────────────────────────────

printf "\nInitializing local repository in '%s'...\n" "$REPO_PATH"
cd "$REPO_PATH"
git init
git branch -M main
git remote add origin git@bitbucket.org:jorisvdijk/"$REPO_NAME".git
git remote set-url --add --push origin git@bitbucket.org:jorisvdijk/"$REPO_NAME".git
git remote set-url --add --push origin git@github.com:jorisvandijk/"$REPO_NAME".git
git remote set-url --add --push origin git@gitlab.com:jorisvandijk/"$REPO_NAME".git
git remote set-url --add --push origin git@codeberg.org:jorisvandijk/"$REPO_NAME".git

printf "\nDone. Run 'git push origin main' after your first commit.\n"
