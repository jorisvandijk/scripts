#!/usr/bin/env bash
#	jGamesNostalgiaDl 2.1
#	Interactive game downloader for GamesNostalgia.com
#	Dependencies: curl, fzf
#	Usage: jGamesNostalgiaDl [-s <query>] [-d <slug>] [-p <platform>] [-a <tag>] [-b]
#
#	By Joris van Dijk | Jorisvandijk.com
#	Licensed under the MIT license

source "$(dirname "${BASH_SOURCE[0]}")/j"

[[ "$1" == "--version" || "$1" == "-v" ]] && j::version "$0" && exit 0
[[ "$1" == "--help" || "$1" == "-h" ]]    && j::help "jGamesNostalgiaDl" && exit 0

set -eo pipefail

BASE_URL="https://gamesnostalgia.com"
UA="Mozilla/5.0"

TIER_LIST=(
    windows
    windows-3.x
    dos
    game-boy-advance
    amiga
    snes
    nes
    game-boy-color
    commodore-64
    atari-5200
    atari-2600
    amstrad-cpc
    atari-8-bit
    atari-st
    genesis
    apple-ii
    sega-master-system
    msx
    pc-engine
)

command -v fzf &>/dev/null || j::die "fzf is required but not installed (brew install fzf)"

usage() {
    cat << 'EOF'
Usage:
  jGamesNostalgiaDl                      Interactive mode
  jGamesNostalgiaDl -b                   Bulk download mode
  jGamesNostalgiaDl -s <query>           Search for a game
  jGamesNostalgiaDl -d <slug> [-p plat]  Download by slug
  jGamesNostalgiaDl -a <tag>  [-p plat]  Download all games in a tag/genre

Examples:
  jGamesNostalgiaDl -s doom
  jGamesNostalgiaDl -d doom
  jGamesNostalgiaDl -d "doom-ii_" -p dos
  jGamesNostalgiaDl -b
  jGamesNostalgiaDl -a adventure
  jGamesNostalgiaDl -a "point+and+click" -p dos
EOF
    exit 1
}

fetch_search_html() {
    local q
    q=$(echo "$1" | sed 's/ /+/g')
    curl -sL --max-time 15 -A "$UA" "${BASE_URL}/search?q=${q}&lang=en"
}

fetch_results() {
    local html
    html=$(fetch_search_html "$1")

    local slugs=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && slugs+=("$line")
    done < <(echo "$html" | grep -oE 'href="/game/[^/"]+' | sed 's|href="/game/||' | awk '!seen[$0]++')

    for slug in "${slugs[@]}"; do
        local block
        block=$(echo "$html" | grep -A12 "href=\"/game/${slug}\"" | head -13)
        local title platforms year genre
        title=$(echo    "$block" | grep -oE '<a href="/game/[^"]+">([^<]+)</a>' | head -1 | sed 's|<a href="[^"]*">||;s|</a>||')
        platforms=$(echo "$block" | grep -oE "title='[a-zA-Z0-9 _-]+'" | sed "s/title='//;s/'//" | tr '\n' ',' | sed 's/,$//')
        year=$(echo     "$block" | grep -oE "href='/games/year/[0-9]+'" | grep -oE '[0-9]{4}' | head -1)
        genre=$(echo    "$block" | grep -oE "Genre: <a href='[^']*'>[^<]+" | sed "s|Genre: <a href='[^']*'>||")
        [[ -n "$title" ]] && printf "%s|%s|%s|%s|%s\n" "$slug" "$title" "${platforms:--}" "${year:--}" "${genre:--}"
    done
}

do_search() {
    echo ""
    echo "Results for: $1"
    echo "──────────────────────────────────────────"
    while IFS='|' read -r slug title platforms year genre; do
        echo ""
        printf "  \033[1m%s\033[0m\n" "$title"
        printf "  Platform : %s\n" "$platforms"
        printf "  Year     : %s   Genre: %s\n" "$year" "$genre"
        printf "  Slug     : %s\n" "$slug"
    done < <(fetch_results "$1")
    echo ""
}

get_english_ids() {
    local slug="$1"
    local platform="$2"
    local game_html="$3"
    local section="$game_html"

    if [[ -n "$platform" ]]; then
        local buf="" capture=0
        while IFS= read -r line; do
            if echo "$line" | grep -qi "id='downloads-${platform}'"; then
                capture=1
            elif [[ $capture -eq 1 ]] && echo "$line" | grep -qE "id='downloads-[^']+'"; then
                capture=0
            fi
            [[ $capture -eq 1 ]] && buf="${buf}${line}"$'\n'
        done < <(echo "$game_html")
        section="$buf"
    fi

    echo "$section" \
        | sed 's/<a /\n<a /g' \
        | grep "href='/download/${slug}/" \
        | grep "enflag" \
        | grep -oE "href='/download/${slug}/[0-9]+" \
        | sed "s|href='/download/${slug}/||" \
        | sort -u
}

download_id() {
    local slug="$1"
    local id="$2"

    local dl_page
    dl_page=$(curl -sL --max-time 15 -A "$UA" "${BASE_URL}/download/${slug}/${id}")

    local g
    g=$(echo "$dl_page" | grep -oE 'g=[0-9]+&f=' | sed 's/g=//;s/&f=//' || true)
    [[ -z "$g" ]] && echo "  [!] Could not find g param for ID $id — skipping" && return 1

    local api
    api=$(curl -sL --max-time 15 -A "$UA" \
        "${BASE_URL}/download_post_call.php?g=${g}&f=${id}&gpath=${slug}&lang=en&rnd=0.${RANDOM}")

    local url
    url=$(echo "$api" | grep -oE "href='https://[^']+" | sed "s/href='//")
    [[ -z "$url" ]] && echo "  [!] Could not extract file URL for ID $id — skipping" && return 1

    local filename
    filename=$(echo "$url" | sed 's|.*/||')

    if [[ -f "$filename" ]]; then
        echo "  [=] Already exists: $filename — skipping"
        return 0
    fi

    echo "  Downloading: $filename"
    if curl -L -C - -A "$UA" -o "$filename" "$url" --progress-bar; then
        echo "  [✓] Saved: $filename ($(du -sh "$filename" | cut -f1))"
    else
        echo "  [!] Download failed — partial file kept, will resume on next run"
        return 1
    fi
}

do_download() {
    local slug="$1"
    local platform="$2"

    echo ""
    echo "Fetching game page for: $slug"
    local game_html
    game_html=$(curl -sL --max-time 15 -A "$UA" "${BASE_URL}/game/${slug}")

    local ids=()
    while IFS= read -r id; do
        [[ -n "$id" ]] && ids+=("$id")
    done < <(get_english_ids "$slug" "$platform" "$game_html")

    [[ ${#ids[@]} -eq 0 ]] && echo "No English downloads found for: $slug${platform:+ (platform: $platform)}" && return 1

    echo "Found ${#ids[@]} English download(s)"
    echo ""

    for id in "${ids[@]}"; do
        download_id "$slug" "$id"
    done
}

do_interactive() {
    while true; do
        local picked
        picked=$(pick_game_interactive)

        [[ -z "$picked" ]] && exit 0

        local slug platform game_html
        slug=$(echo "$picked" | cut -d'|' -f1)
        platform=$(echo "$picked" | cut -d'|' -f2)

        game_html=$(curl -sL --max-time 15 -A "$UA" "${BASE_URL}/game/${slug}")

        local ids=()
        while IFS= read -r id; do
            [[ -n "$id" ]] && ids+=("$id")
        done < <(get_english_ids "$slug" "$platform" "$game_html")

        [[ ${#ids[@]} -eq 0 ]] && echo "No English downloads found." && continue

        echo "Found ${#ids[@]} English download(s) for '$slug' [$platform]"
        echo ""
        for id in "${ids[@]}"; do
            download_id "$slug" "$id"
        done

        echo ""
        echo "Done. Press Enter to search again or Esc to quit."
    done
}

pick_game_interactive() {
    echo "" >&2
    printf "Search (Esc to cancel): " >&2
    local query
    read -r query || return 0
    [[ -z "$query" ]] && return 0

    echo "Searching…" >&2
    local results
    results=$(fetch_results "$query")
    [[ -z "$results" ]] && echo "No results for: $query" >&2 && return 0

    local selection
    selection=$(echo "$results" | \
        awk -F'|' '{ printf "%-40s  %-25s  %-6s  %s\n|%s\n", $2, $3, $4, $5, $1 }' | \
        paste - - | \
        fzf --prompt="Select game > " \
            --delimiter="|" \
            --with-nth=1 \
            --height=40% \
            --layout=reverse \
            --border \
            --bind="esc:abort" \
        || true)

    [[ -z "$selection" ]] && return 0

    local slug
    slug=$(echo "$selection" | cut -d'|' -f2 | tr -d ' ')

    local title
    title=$(echo "$results" | awk -F'|' -v s="$slug" '$1 == s { print $2; exit }')

    echo "Fetching platforms…" >&2
    local game_html
    game_html=$(curl -sL --max-time 15 -A "$UA" "${BASE_URL}/game/${slug}")

    local platform
    platform=$(select_platform "$game_html") || return 0

    local label="${title:-$slug}"
    [[ -n "$platform" ]] && label="${label} [${platform}]"
    printf "%s|%s|%s\n" "$slug" "$platform" "$label"
}

do_bulk() {
    local bulk_slugs=()
    local bulk_platforms=()
    local bulk_labels=()

    echo ""
    echo "Bulk download mode"
    echo "  + Add game      — search and queue a game"
    echo "  ✓ item          — select a queued item to remove it"
    echo "  ▶ Download all  — start downloading everything in the queue"
    echo ""

    while true; do
        local menu=""
        local i=0
        while [[ $i -lt ${#bulk_slugs[@]} ]]; do
            menu="${menu}  ✓  ${bulk_labels[$i]}"$'\n'
            i=$((i + 1))
        done

        [[ ${#bulk_slugs[@]} -gt 0 ]] && menu="${menu}▶  Download all (${#bulk_slugs[@]})"$'\n'
        menu="${menu}+  Add game"$'\n'
        menu="${menu}✗  Cancel"

        local header
        if [[ ${#bulk_slugs[@]} -eq 0 ]]; then
            header="Queue is empty"
        else
            header="${#bulk_slugs[@]} game(s) in queue — select ✓ item to remove"
        fi

        local choice
        choice=$(printf "%s" "$menu" | fzf \
            --prompt="Bulk > " \
            --height=50% \
            --layout=reverse \
            --border \
            --header="$header" \
            --bind="esc:abort" \
            || true)

        [[ -z "$choice" ]] && return 0

        if echo "$choice" | grep -q "^▶"; then
            echo ""
            echo "Starting bulk download — ${#bulk_slugs[@]} game(s)…"
            local i=0
            local failed_labels=()
            while [[ $i -lt ${#bulk_slugs[@]} ]]; do
                echo ""
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "  [$(( i + 1 ))/${#bulk_slugs[@]}] ${bulk_labels[$i]}"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                do_download "${bulk_slugs[$i]}" "${bulk_platforms[$i]}" || failed_labels+=("${bulk_labels[$i]}")
                i=$((i + 1))
            done
            echo ""
            if [[ ${#failed_labels[@]} -eq 0 ]]; then
                echo "All downloads complete!"
            else
                echo "Downloads complete — ${#failed_labels[@]} failed:"
                for label in "${failed_labels[@]}"; do
                    echo "  [✗] $label"
                done
            fi
            return 0

        elif echo "$choice" | grep -q "^+"; then
            local picked
            picked=$(pick_game_interactive)

            if [[ -n "$picked" ]]; then
                local pslug pplatform plabel
                pslug=$(echo "$picked" | cut -d'|' -f1)
                pplatform=$(echo "$picked" | cut -d'|' -f2)
                plabel=$(echo "$picked" | cut -d'|' -f3-)

                local dup=0
                local j=0
                while [[ $j -lt ${#bulk_slugs[@]} ]]; do
                    if [[ "${bulk_slugs[$j]}" == "$pslug" && "${bulk_platforms[$j]}" == "$pplatform" ]]; then
                        dup=1
                        break
                    fi
                    j=$((j + 1))
                done

                if [[ $dup -eq 1 ]]; then
                    echo "  Already in queue: $plabel"
                    sleep 1
                else
                    bulk_slugs+=("$pslug")
                    bulk_platforms+=("$pplatform")
                    bulk_labels+=("$plabel")
                    echo "  ✓ Added: $plabel"
                    sleep 0.5
                fi
            fi

        elif echo "$choice" | grep -q "^✗"; then
            return 0

        else
            local clicked_label
            clicked_label=$(echo "$choice" | sed 's/^  ✓  //')

            local new_slugs=() new_platforms=() new_labels=()
            local j=0
            while [[ $j -lt ${#bulk_slugs[@]} ]]; do
                if [[ "${bulk_labels[$j]}" != "$clicked_label" ]]; then
                    new_slugs+=("${bulk_slugs[$j]}")
                    new_platforms+=("${bulk_platforms[$j]}")
                    new_labels+=("${bulk_labels[$j]}")
                fi
                j=$((j + 1))
            done

            if [[ ${#new_slugs[@]} -gt 0 ]]; then
                bulk_slugs=("${new_slugs[@]}")
                bulk_platforms=("${new_platforms[@]}")
                bulk_labels=("${new_labels[@]}")
            else
                bulk_slugs=() bulk_platforms=() bulk_labels=()
            fi

            echo "  ✗ Removed: $clicked_label"
            sleep 0.5
        fi
    done
}

extract_platforms() {
    local game_html="$1"
    echo "$game_html" | grep -oE "id='downloads-[^']+'" | sed "s/id='downloads-//;s/'//" | sort -u
}

select_platform() {
    local game_html="$1"
    local platforms=()
    while IFS= read -r p; do
        [[ -n "$p" ]] && platforms+=("$p")
    done < <(extract_platforms "$game_html")

    [[ ${#platforms[@]} -eq 0 ]] && return 1

    if [[ ${#platforms[@]} -eq 1 ]]; then
        echo "Platform: ${platforms[0]} (only option)" >&2
        echo "${platforms[0]}"
        return 0
    fi

    local chosen
    chosen=$(printf '%s\n' "${platforms[@]}" | \
        fzf --prompt="Select platform > " \
            --height=40% \
            --layout=reverse \
            --border \
            --bind="esc:abort" \
        || true)
    [[ -z "$chosen" ]] && return 1
    echo "$chosen"
}

pick_platform_by_tier() {
    local available="$1"
    for tier_plat in "${TIER_LIST[@]}"; do
        while IFS= read -r avail; do
            [[ "$avail" == "$tier_plat" ]] && echo "$tier_plat" && return 0
        done < <(echo "$available")
    done
    return 1
}

fetch_tag_slugs() {
    local tag="$1"
    local page=1
    local all_slugs=""

    while true; do
        local url
        if [[ $page -eq 1 ]]; then
            url="${BASE_URL}/games/${tag}"
        else
            url="${BASE_URL}/games/${tag}/page/${page}"
        fi

        echo "  Fetching page ${page}…" >&2
        local html
        html=$(curl -sL --max-time 15 -A "$UA" "$url")
        [[ -z "$html" ]] && break

        local slugs
        slugs=$(echo "$html" | grep -oE 'href="/game/[^"]+' | sed 's|href="/game/||' | awk '!seen[$0]++')
        [[ -z "$slugs" ]] && break

        all_slugs="${all_slugs}${slugs}"$'\n'

        echo "$html" | grep -q "href='/games/${tag}/page/$((page + 1))'" || break
        page=$((page + 1))
    done

    echo "$all_slugs" | awk 'NF && !seen[$0]++'
}

do_auto() {
    local tag="$1"
    local platform_override="$2"

    echo ""
    echo "Fetching game list for tag/genre: $tag"
    local slugs=()
    while IFS= read -r slug; do
        [[ -n "$slug" ]] && slugs+=("$slug")
    done < <(fetch_tag_slugs "$tag")

    [[ ${#slugs[@]} -eq 0 ]] && j::die "no games found for: $tag"

    echo "Found ${#slugs[@]} game(s) — starting download…"
    echo ""

    local i=0
    for slug in "${slugs[@]}"; do
        i=$((i + 1))
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "  [${i}/${#slugs[@]}] ${slug}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

        local game_html
        game_html=$(curl -sL --max-time 15 -A "$UA" "${BASE_URL}/game/${slug}")

        local available
        available=$(echo "$game_html" | grep -oE "id='downloads-[^']+'" | sed "s/id='downloads-//;s/'//" | sort -u)

        if [[ -z "$available" ]]; then
            echo "  [!] No download sections found — skipping"
            echo ""
            continue
        fi

        local platform
        if [[ -n "$platform_override" ]]; then
            platform="$platform_override"
        else
            platform=$(pick_platform_by_tier "$available") || true
        fi

        if [[ -z "$platform" ]]; then
            echo "  [!] No platform in tierlist available for this game"
            echo "      Available: $(echo "$available" | tr '\n' ' ')"
            echo "      Skipping."
            echo ""
            continue
        fi

        echo "  Platform: $platform"

        local ids=()
        while IFS= read -r id; do
            [[ -n "$id" ]] && ids+=("$id")
        done < <(get_english_ids "$slug" "$platform" "$game_html")

        if [[ ${#ids[@]} -eq 0 ]]; then
            echo "  [!] No English downloads found for platform: $platform — skipping"
            echo ""
            continue
        fi

        echo "  Found ${#ids[@]} English download(s)"
        echo ""
        for id in "${ids[@]}"; do
            download_id "$slug" "$id"
        done
        echo ""
    done

    echo "All done — ${i} game(s) processed."
}

# ── Entry point ───────────────────────────────────────────────────────────────

MODE="" QUERY="" SLUG="" PLATFORM="" TAG=""

while getopts "s:d:p:a:b" opt; do
    case $opt in
        s) MODE=search;   QUERY="$OPTARG"  ;;
        d) MODE=download; SLUG="$OPTARG"   ;;
        p) PLATFORM="$OPTARG"              ;;
        a) MODE=auto;     TAG="$OPTARG"    ;;
        b) MODE=bulk                        ;;
        *) usage ;;
    esac
done

[[ -z "$MODE" && $OPTIND -eq 1 ]] && MODE=interactive

case "$MODE" in
    search)      do_search "$QUERY" ;;
    download)    do_download "$SLUG" "$PLATFORM" ;;
    interactive) do_interactive ;;
    bulk)        do_bulk ;;
    auto)        do_auto "$TAG" "$PLATFORM" ;;
    *)           usage ;;
esac
