#!/usr/bin/env bash
#
# nexus-verify-dir — verify Nexus mod downloads in the current directory.
#
# For each .zip/.7z/.rar file, extracts the mod ID from the Nexus filename
# pattern, looks up the expected size via the Nexus API, compares to on-disk
# size, then optionally runs an archive integrity test.
#
# Usage:
#   cd /path/to/mods && nexus-verify-dir [--game <slug>] [--skip-archive-test]
#
# Defaults:
#   game = skyrimspecialedition
#
# Config:
#   ~/.config/nexus-modlist-dl/config  (mode 0600)
#     NEXUS_API_KEY="..."
#
set -euo pipefail

GAME="skyrimspecialedition"
SKIP_ARCHIVE_TEST=0
API_BASE="https://api.nexusmods.com/v1"
CONFIG_FILE="${HOME}/.config/nexus-modlist-dl/config"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --game)               GAME="$2"; shift 2 ;;
        --skip-archive-test)  SKIP_ARCHIVE_TEST=1; shift ;;
        -h|--help)
            echo "Usage: nexus-verify-dir [--game <slug>] [--skip-archive-test]"
            exit 0 ;;
        *)
            echo "unknown arg: $1" >&2
            exit 2 ;;
    esac
done

[[ -f "${CONFIG_FILE}" ]] || { echo "missing ${CONFIG_FILE}" >&2; exit 1; }
# shellcheck source=/dev/null
source "${CONFIG_FILE}"
[[ -n "${NEXUS_API_KEY:-}" ]] || { echo "NEXUS_API_KEY not set" >&2; exit 1; }

command -v jq   >/dev/null || { echo "jq not found" >&2; exit 1; }
command -v curl >/dev/null || { echo "curl not found" >&2; exit 1; }

# stat: macOS uses -f%z, Linux uses -c%s
if stat -f%z /dev/null >/dev/null 2>&1; then
    STAT_SIZE() { stat -f%z "$1"; }
else
    STAT_SIZE() { stat -c%s "$1"; }
fi

declare -A FILES_JSON_CACHE

# Robust API call that catches HTTP errors and malformed responses.
api_get_files() {
    local mod_id="$1"
    if [[ -n "${FILES_JSON_CACHE[$mod_id]:-}" ]]; then
        printf '%s' "${FILES_JSON_CACHE[$mod_id]}"
        return 0
    fi
    sleep 1
    local body http_code tmp_body
    tmp_body=$(mktemp)
    http_code=$(curl -sS \
        -w '%{http_code}' \
        -o "${tmp_body}" \
        -H "apikey: ${NEXUS_API_KEY}" \
        -H "Accept: application/json" \
        "${API_BASE}/games/${GAME}/mods/${mod_id}/files.json" 2>/dev/null) || {
        rm -f "${tmp_body}"
        echo "curl failed for mod ${mod_id}" >&2
        return 1
    }
    body=$(cat "${tmp_body}")
    rm -f "${tmp_body}"
    if [[ "${http_code}" != "200" ]]; then
        local msg
        msg=$(jq -r '.message // .error // empty' <<< "${body}" 2>/dev/null || true)
        echo "HTTP ${http_code} for mod ${mod_id}${msg:+: ${msg}}" >&2
        return 1
    fi
    if ! jq -e '.files | type == "array"' >/dev/null 2>&1 <<< "${body}"; then
        local msg
        msg=$(jq -r '.message // .error // "no .files array"' <<< "${body}" 2>/dev/null || echo "unparseable")
        echo "malformed response for mod ${mod_id}: ${msg}" >&2
        return 1
    fi
    FILES_JSON_CACHE[$mod_id]="${body}"
    printf '%s' "${body}"
}

# Extract mod ID from a Nexus filename.
# Nexus filenames are typically "<name>-<modid>-<version>-<timestamp>.<ext>".
# The mod ID is the first all-digit dash-separated token whose length is
# less than 10 (10-digit tokens are unix timestamps).
#
# Known limitation: this heuristic fails when the version precedes the mod ID
# in the filename (e.g. legacy "SMIM SE 2-08-659-2-08.7z"). For those cases,
# verify manually with curl.
extract_mod_id() {
    local fname="$1"
    local base="${fname%.*}"
    base="${base%.7z}"  # handle accidental double extension like "Foo.7z-901-4-2.7z"
    local IFS='-'
    local -a tokens
    read -ra tokens <<< "${base}"
    local tok
    for tok in "${tokens[@]}"; do
        if [[ "$tok" =~ ^[0-9]+$ ]] && [[ "${#tok}" -lt 10 ]]; then
            echo "$tok"
            return 0
        fi
    done
    return 1
}

shopt -s nullglob
mapfile -t archives < <(printf '%s\n' *.zip *.7z *.rar | sort)
shopt -u nullglob

if [[ ${#archives[@]} -eq 0 ]]; then
    echo "no archives found in $(pwd)" >&2
    exit 1
fi

echo "Verifying ${#archives[@]} archive(s) against Nexus API (game: ${GAME})"
echo

declare -i ok=0 size_bad=0 archive_bad=0 unparseable=0 api_failed=0 not_found=0
declare -a issues=()

for fname in "${archives[@]}"; do
    if ! mod_id=$(extract_mod_id "$fname"); then
        printf '  ??       %s (no mod ID extractable from filename)\n' "$fname"
        unparseable+=1
        issues+=("$fname: no mod ID extractable")
        continue
    fi

    if ! files_json=$(api_get_files "${mod_id}"); then
        printf '  API-ERR  %s (mod %s)\n' "$fname" "$mod_id"
        api_failed+=1
        issues+=("$fname: API request failed for mod ${mod_id}")
        continue
    fi

    # Pull both size_in_bytes and size (KB) for the matching file.
    # size_in_bytes is preferred (byte-exact); size is the fallback for older
    # files where size_in_bytes was never backfilled by Nexus.
    # Format: "size_in_bytes|size_kb" — either may be "null".
    sizes=$(jq -r --arg name "$fname" '
        .files // [] |
        map(select(.file_name == $name)) |
        .[0] |
        if . == null then "||"
        else "\(.size_in_bytes)|\(.size)" end
    ' <<< "${files_json}" 2>/dev/null)

    IFS='|' read -r expected_bytes expected_kb <<< "${sizes}"

    actual=$(STAT_SIZE "$fname")
    expected_source=""
    expected=""

    if [[ -n "${expected_bytes}" && "${expected_bytes}" != "null" ]]; then
        expected="${expected_bytes}"
        expected_source="bytes"
    elif [[ -n "${expected_kb}" && "${expected_kb}" != "null" ]]; then
        expected=$(( expected_kb * 1024 ))
        expected_source="kb"
    else
        printf '  NOT-LIST %s (not in mod %s current files, or no size data)\n' "$fname" "$mod_id"
        not_found+=1
        issues+=("$fname: not in mod ${mod_id} current file list (likely outdated)")
        continue
    fi

    # Compare with tolerance:
    #   - byte-exact source: tolerate ±1 byte (API has been seen off by one)
    #   - KB-rounded source: tolerate up to 1024 bytes (KB rounding)
    if [[ "${expected_source}" == "kb" ]]; then
        tolerance=1024
    else
        tolerance=1
    fi

    diff=$(( actual > expected ? actual - expected : expected - actual ))

    if [[ ${diff} -le ${tolerance} ]]; then
        if [[ ${diff} -eq 0 ]]; then
            printf '  OK       %s (%s bytes)\n' "$fname" "$actual"
        else
            printf '  OK*      %s (%s bytes, API reports %s via %s — diff %s within tolerance)\n' \
                "$fname" "$actual" "$expected" "$expected_source" "$diff"
        fi
    else
        printf '  SIZE-BAD %s (expected %s, got %s, diff %s, source: %s)\n' \
            "$fname" "$expected" "$actual" "$diff" "$expected_source"
        size_bad+=1
        issues+=("$fname: size mismatch (expected ${expected}, got ${actual}, diff ${diff})")
        continue
    fi

    if [[ ${SKIP_ARCHIVE_TEST} -eq 0 ]]; then
        case "$fname" in
            *.zip)
                if ! unzip -tq "$fname" >/dev/null 2>&1; then
                    printf '  ARCH-BAD %s (archive integrity test failed)\n' "$fname"
                    archive_bad+=1
                    issues+=("$fname: archive integrity test failed")
                    continue
                fi
                ;;
            *.7z)
                if ! 7z t "$fname" >/dev/null 2>&1; then
                    printf '  ARCH-BAD %s (archive integrity test failed)\n' "$fname"
                    archive_bad+=1
                    issues+=("$fname: archive integrity test failed")
                    continue
                fi
                ;;
            *.rar)
                if command -v unrar >/dev/null; then
                    if ! unrar t -inul "$fname" >/dev/null 2>&1; then
                        printf '  ARCH-BAD %s (archive integrity test failed)\n' "$fname"
                        archive_bad+=1
                        issues+=("$fname: archive integrity test failed")
                        continue
                    fi
                fi
                ;;
        esac
    fi

    ok+=1
done

cat <<EOSUMMARY

================================================================
  Summary
================================================================
  Total archives:        ${#archives[@]}
  OK:                    ${ok}
  Size mismatch:         ${size_bad}
  Archive corrupt:       ${archive_bad}
  Not in mod file list:  ${not_found}
  Unparseable filename:  ${unparseable}
  API failures:          ${api_failed}
EOSUMMARY

if [[ ${#issues[@]} -gt 0 ]]; then
    echo
    echo "Issues:"
    for i in "${issues[@]}"; do
        printf '  - %s\n' "$i"
    done
    exit 1
fi



