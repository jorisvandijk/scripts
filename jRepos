#!/usr/bin/env bash
#	jRepos 2.1
#	Show git status of all repositories in ~/git
#	Dependencies: git
#	Usage: jRepos
#
#	By Joris van Dijk | Jorisvandijk.com
#	Licensed under the MIT license

source "$(dirname "${BASH_SOURCE[0]}")/j"

[[ "$1" == "--version" || "$1" == "-v" ]] && j::version "$0" && exit 0
[[ "$1" == "--help"    || "$1" == "-h" ]] && j::help "jRepos" && exit 0
[[ -n "$1" ]]                             && j::die "usage: jRepos (no arguments)"

GIT_BASE_DIR="${HOME}/git"

collect_repo_status() {
    local repo_path="$1"
    local orig_dir="$PWD"

    [[ ! -d "$repo_path/.git" ]] && echo "not a git repo" && return

    cd "$repo_path" || return

    local status_output ahead_behind behind ahead
    status_output="$(git status --porcelain 2>/dev/null)"
    ahead_behind="$(git rev-list --count --left-right @{upstream}...HEAD 2>/dev/null || echo "0	0")"
    behind="$(echo "$ahead_behind" | cut -f1)"
    ahead="$(echo "$ahead_behind" | cut -f2)"

    local staged=0 modified=0 untracked=0
    if [[ -n "$status_output" ]]; then
        modified="$(echo "$status_output" | grep -c "^.M\|^M" || true)"
        untracked="$(echo "$status_output" | grep -c "^??" || true)"
        staged="$(echo "$status_output" | grep -c "^[MADRC]" || true)"
    fi

    cd "$orig_dir" || true

    printf '%s|%s|%s|%s|%s\n' "$staged" "$modified" "$untracked" "$ahead" "$behind"
}

format_repo_status() {
    local raw="$1"
    local staged modified untracked ahead behind
    IFS='|' read -r staged modified untracked ahead behind <<< "$raw"

    local status_parts=()
    [[ $staged -gt 0 ]]    && status_parts+=("$staged staged")
    [[ $modified -gt 0 ]]  && status_parts+=("$modified modified")
    [[ $untracked -gt 0 ]] && status_parts+=("$untracked untracked")
    [[ $ahead -gt 0 ]]     && status_parts+=("ahead $ahead")
    [[ $behind -gt 0 ]]    && status_parts+=("behind $behind")

    if [[ ${#status_parts[@]} -eq 0 ]]; then
        echo "clean"
    else
        local IFS=" "
        echo "${status_parts[*]}"
    fi
}

get_repo_status() {
    local raw
    raw=$(collect_repo_status "$1")
    [[ "$raw" == "not a git repo" ]] && echo "not a git repo" && return
    format_repo_status "$raw"
}

classify_status() {
    local status="$1"
    if [[ "$status" == "clean" ]]; then
        echo "clean"
    elif [[ "$status" =~ (ahead|behind) ]]; then
        echo "sync"
    else
        echo "dirty"
    fi
}

[[ ! -d "$GIT_BASE_DIR" ]] && j::die "git directory not found: $GIT_BASE_DIR"

sync_entries=()
dirty_entries=()
clean_entries=()

for repo_dir in "$GIT_BASE_DIR"/*/; do
    [[ -d "$repo_dir/.git" ]] || continue
    repo_name="$(basename "$repo_dir")"
    repo_status="$(get_repo_status "$repo_dir")"
    classification="$(classify_status "$repo_status")"

    case "$classification" in
        sync)  sync_entries+=("${repo_name}|${repo_status}") ;;
        dirty) dirty_entries+=("${repo_name}|${repo_status}") ;;
        clean) clean_entries+=("${repo_name}|${repo_status}") ;;
    esac
done

total=$(( ${#sync_entries[@]} + ${#dirty_entries[@]} + ${#clean_entries[@]} ))
[[ $total -eq 0 ]] && echo "No git repositories found in: $GIT_BASE_DIR" && exit 0

for entry in "${sync_entries[@]}"; do
    printf "${J_RED}%-20s %s${J_RESET}\n" "${entry%|*}" "${entry#*|}"
done

for entry in "${dirty_entries[@]}"; do
    printf "${J_YELLOW}%-20s %s${J_RESET}\n" "${entry%|*}" "${entry#*|}"
done

for entry in "${clean_entries[@]}"; do
    printf "${J_GREEN}%-20s %s${J_RESET}\n" "${entry%|*}" "${entry#*|}"
done
